# ─────────────────────────────────────────────
# LLM Backend — pick one: "claude" or "copilot"
# ─────────────────────────────────────────────
LLM_BACKEND=claude

# ── Claude (Anthropic) ───────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (fully local, no data leaves your machine) ─
# Requires Ollama running: https://ollama.com
# Start it with: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
# Model to use — must be pulled first: ollama pull <model>
# Recommended picks by RAM:
#   8GB  → llama3.1:8b  or  mistral:7b
#   16GB → llama3.3:8b  or  mistral-small3.1:7b
#   32GB → llama3.3:70b or  qwen3:14b
OLLAMA_MODEL=llama3.1:8b

# ── GitHub Copilot (OpenAI-compatible) ───────
# Generate a token at https://github.com/settings/tokens
# Requires: Models permission (read)
GITHUB_TOKEN=ghp_...

# ── OpenRouter ────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Model to use — pick any from https://openrouter.ai/models
# Free options: mistralai/mistral-7b-instruct:free, meta-llama/llama-3-8b-instruct:free
OPENROUTER_MODEL=openrouter/free
# Optional: shown in OpenRouter dashboard for attribution
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_SITE_NAME=Oratio

# ─────────────────────────────────────────────
# Path to your Writing Style Guide PDF
# Can be absolute or relative to this file
# ─────────────────────────────────────────────
PDF_PATH=writing-style-documentation.pdf

# ─────────────────────────────────────────────
# Specialisation context (optional)
# Tailor feedback for a specific business unit or audience.
# Leave empty to use the style guide rules as-is.
# ─────────────────────────────────────────────
# EXTRA_CONTEXT=You are reviewing content for an IBM consulting engagement targeting C-suite executives.
# EXTRA_CONTEXT=This content is for a financial services audience. Precision and compliance language matter.
# EXTRA_CONTEXT=You are reviewing developer documentation for a cloud platform product.
# EXTRA_CONTEXT=This content targets HR professionals. Plain language and inclusivity rules take priority.
EXTRA_CONTEXT=

# ─────────────────────────────────────────────
# API endpoint override (usually not needed)
# Uncomment and set only if your environment points httpx at a local proxy
# (e.g. Ollama at localhost:11434) that intercepts the Anthropic SDK.
# ─────────────────────────────────────────────
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─────────────────────────────────────────────
# Optional tuning
# ─────────────────────────────────────────────
# How many PDF chunks to retrieve per query (default: 5)
RETRIEVER_K=5

# Chunk size in characters (default: 1000)
CHUNK_SIZE=1000

# Overlap between chunks in characters (default: 200)
CHUNK_OVERLAP=200
